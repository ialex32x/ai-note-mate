{
	"name": "ai-note-mate",
	"version": "0.0.0-managed-by-tag",
	"description": "This is a sample plugin for Obsidian (https://obsidian.md)",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "npm run lint && npm run lint:css && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production && npm run check:eslint-disables && npm run check:locales",
		"lint": "eslint .",
		"lint:css": "stylelint \"src/styles/**/*.less\"",
		"check:eslint-disables": "node scripts/check-eslint-disables.mjs",
		"check:locales": "node scripts/check-locales.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:bing": "tsx test-bing-search.ts"
	},
	"keywords": [
		"ai",
		"openai",
		"gemini",
		"assistant"
	],
	"license": "MIT",
	"devDependencies": {
		"@codemirror/autocomplete": "^6.20.1",
		"@codemirror/commands": "^6.10.3",
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "6.5.0",
		"@codemirror/view": "6.38.6",
		"@eslint/js": "9.30.1",
		"@eslint/json": "^2.0.1",
		"@types/node": "^22.20.0",
		"obsidian": "~1.12.3",
		"eslint-plugin-obsidianmd": "0.4.1",
		"esbuild": "0.28.1",
		"globals": "14.0.0",
		"jiti": "2.7.0",
		"less": "^4.6.7",
		"postcss-less": "^6.0.0",
		"stylelint": "^17.14.0",
		"stylelint-config-recommended": "^18.0.0",
		"tslib": "^2.8.1",
		"tsx": "^4.23.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "8.62.1",
		"vitest": "^4.1.9",
		"moment": "2.29.4"
	},
	"dependencies": {}
}
