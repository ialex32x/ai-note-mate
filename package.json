{
	"name": "ai-note-mate",
	"version": "0.0.0-managed-by-tag",
	"description": "This is a sample plugin for Obsidian (https://obsidian.md)",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "npm run lint && npm run lint:css && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint .",
		"lint:css": "stylelint \"src/styles/**/*.less\"",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:bing": "tsx test-bing-search.ts"
	},
	"keywords": [
		"ai",
		"openai",
		"gemini",
		"assistant"
	],
	"license": "0-BSD",
	"devDependencies": {
		"@codemirror/autocomplete": "^6.20.1",
		"@codemirror/commands": "^6.10.3",
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "6.5.0",
		"@codemirror/view": "6.38.6",
		"@eslint/js": "9.30.1",
		"@eslint/json": "^0.14.0",
		"@types/node": "^22.0.0",
		"esbuild": "0.28.0",
		"eslint-plugin-obsidianmd": "0.3.0",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"less": "^4.2.0",
		"obsidian": "~1.11.4",
		"postcss-less": "^6.0.0",
		"stylelint": "^17.13.0",
		"stylelint-config-recommended": "^18.0.0",
		"tslib": "2.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.1.5"
	},
	"dependencies": {}
}
